#!/usr/bin/env bash
set -euo pipefail
[ $# -gt 0 ] || { echo "Usage: $0 DURATION [DURATION ...]  (e.g., 15m, 27m, 2h, 90s, mm:ss, hh:mm:ss)"; exit 1; }
trap 'printf "\n"; exit 130' INT

to_secs() {
  local d="$1"
  if [[ $d =~ ^[0-9]+$ ]]; then echo "$d"; return; fi
  if [[ $d =~ ^([0-9]+)h$ ]]; then echo $((10#${BASH_REMATCH[1]}*3600)); return; fi
  if [[ $d =~ ^([0-9]+)m$ ]]; then echo $((10#${BASH_REMATCH[1]}*60)); return; fi
  if [[ $d =~ ^([0-9]+)s$ ]]; then echo $((10#${BASH_REMATCH[1]})); return; fi
  if [[ $d =~ ^([0-9]+):([0-9]{2})$ ]]; then echo $((10#${BASH_REMATCH[1]}*60 + 10#${BASH_REMATCH[2]})); return; fi
  if [[ $d =~ ^([0-9]+):([0-9]{2}):([0-9]{2})$ ]]; then echo $((10#${BASH_REMATCH[1]}*3600 + 10#${BASH_REMATCH[2]}*60 + 10#${BASH_REMATCH[3]})); return; fi
  echo "Bad duration: $d" >&2; return 1
}

play_sound() {
  if command -v canberra-gtk-play >/dev/null; then
    canberra-gtk-play -i alarm-clock-elapsed 2>/dev/null || printf '\a'
  else
    printf '\a'
  fi
}

countdown() {
  local secs label end rem
  secs="$1"; label="$2"
  end=$(( SECONDS + secs ))
  while :; do
    rem=$(( end - SECONDS ))
    (( rem <= 0 )) && break
    printf '\r\033[2K%s  %02d:%02d:%02d' "$label" $((rem/3600)) $(((rem/60)%60)) $((rem%60))
    sleep 1
  done
  printf '\r\033[2K%s  00:00:00\n' "$label"
}

for d in "$@"; do
  s=$(to_secs "$d") || exit 1
  countdown "$s" "$d"
  command -v notify-send >/dev/null && notify-send "Timer" "$d done"
  play_sound
done
